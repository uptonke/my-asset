{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Risk reduction simulator",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode",
    "baseline",
    "simulations",
    "summary"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "baseline": {
      "type": "object"
    },
    "simulations": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    }
  }
}
