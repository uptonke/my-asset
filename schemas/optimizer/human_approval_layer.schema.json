{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Human approval layer",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode",
    "approval_policy",
    "approval_tickets",
    "summary"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "approval_policy": {
      "type": "object"
    },
    "approval_tickets": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    }
  }
}
