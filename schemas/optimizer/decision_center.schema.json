{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision center",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode",
    "candidates",
    "decision_summary"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "candidates": {
      "type": "array"
    },
    "decision_summary": {
      "type": "object"
    },
    "warnings": {
      "type": "array"
    }
  }
}
