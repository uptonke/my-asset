{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Optimizer risk diagnostics",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "warnings": {
      "type": "array"
    }
  }
}
