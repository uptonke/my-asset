{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Expected return model",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode",
    "model_policy",
    "asset_expected_return_priors",
    "summary",
    "execution_permission",
    "not_trade_order"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "model_policy": {
      "type": "object"
    },
    "asset_expected_return_priors": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    },
    "execution_permission": {
      "type": "boolean"
    },
    "not_trade_order": {
      "type": "boolean"
    }
  }
}
