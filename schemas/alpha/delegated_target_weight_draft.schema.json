{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "v10.2 Delegated Target Weight & Draft Generator with Price Quality Guard",
  "type": "object",
  "required": [
    "version",
    "status",
    "generated_at",
    "mode",
    "safe_mode",
    "review_only",
    "delegated_draft_mode_enabled",
    "delegated_draft_status",
    "trade_signal_enabled",
    "execution_permission",
    "broker_submission_enabled",
    "not_trade_order",
    "summary",
    "policy",
    "eligible_pool_rows",
    "machine_target_rows",
    "delegated_draft_lines"
  ],
  "properties": {
    "version": { "type": "string" },
    "status": { "type": "string" },
    "generated_at": { "type": "string" },
    "mode": { "type": "string" },
    "safe_mode": { "type": "boolean" },
    "research_only": { "type": "boolean" },
    "review_only": { "type": "boolean" },
    "delegated_draft_mode_enabled": { "type": "boolean" },
    "target_weight_source": { "type": "string" },
    "delegated_draft_status": { "type": "string" },
    "trade_signal_enabled": { "type": "boolean" },
    "execution_permission": { "type": "boolean" },
    "broker_submission_enabled": { "type": "boolean" },
    "official_rebalance_enabled": { "type": "boolean" },
    "auto_trade_enabled": { "type": "boolean" },
    "supabase_write_enabled": { "type": "boolean" },
    "not_trade_order": { "type": "boolean" },
    "not_buy_signal": { "type": "boolean" },
    "not_sell_signal": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["delegated_draft_status", "pool_asset_count", "selected_asset_count", "liquidity_buffer_pct", "draft_line_count", "trade_signal_enabled", "execution_permission", "broker_submission_enabled"],
      "properties": {
        "delegated_draft_status": { "type": "string" },
        "pool_asset_count": { "type": "integer" },
        "selected_asset_count": { "type": "integer" },
        "target_asset_weight_sum_pct": { "type": "number" },
        "liquidity_buffer_pct": { "type": "number" },
        "cash_target_weight_pct": { "type": "number" },
        "draft_line_count": { "type": "integer" },
        "price_quality_excluded_line_count": { "type": "integer" },
        "trade_sizing_requires_real_world_price": { "type": "boolean" },
        "blocker_count": { "type": "integer" },
        "warning_count": { "type": "integer" },
        "trade_signal_enabled": { "type": "boolean" },
        "execution_permission": { "type": "boolean" },
        "broker_submission_enabled": { "type": "boolean" }
      }
    },
    "policy": { "type": "object" },
    "eligible_pool_rows": { "type": "array" },
    "machine_target_rows": { "type": "array" },
    "machine_target_weights_pct": { "type": "object" },
    "delegated_draft_lines": { "type": "array" },
    "sizing_summary": { "type": "object" },
    "price_quality_guard": { "type": "object" },
    "blockers": { "type": "array" },
    "warnings": { "type": "array" },
    "source_context": { "type": "object" },
    "safety_boundary": { "type": "array" }
  }
}
