{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Target Weight Origin Thesis Aggregator",
  "type": "object",
  "required": [
    "version",
    "status",
    "generated_at",
    "safe_mode",
    "research_only",
    "execution_permission",
    "not_trade_order",
    "summary",
    "thesis_rows"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "research_only": {
      "type": "boolean"
    },
    "review_only": {
      "type": "boolean"
    },
    "trade_signal_enabled": {
      "type": "boolean"
    },
    "execution_permission": {
      "type": "boolean"
    },
    "broker_submission_enabled": {
      "type": "boolean"
    },
    "official_rebalance_enabled": {
      "type": "boolean"
    },
    "auto_trade_enabled": {
      "type": "boolean"
    },
    "supabase_write_enabled": {
      "type": "boolean"
    },
    "not_trade_order": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "row_count",
        "execution_permission"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "row_count": {
          "type": "number"
        },
        "execution_permission": {
          "type": "boolean"
        }
      }
    },
    "thesis_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ticker",
          "thesis_summary"
        ],
        "properties": {
          "ticker": {
            "type": "string"
          },
          "source_agreement": {
            "type": "string"
          },
          "thesis_summary": {
            "type": "string"
          },
          "target_origin_thesis": {
            "type": [
              "string",
              "null"
            ]
          },
          "dual_blend_pre_conflict_pct": {
            "type": [
              "number",
              "null"
            ]
          },
          "cloud_delta_vs_current_pct": {
            "type": [
              "number",
              "null"
            ]
          },
          "native_delta_vs_current_pct": {
            "type": [
              "number",
              "null"
            ]
          },
          "final_delta_vs_current_pct": {
            "type": [
              "number",
              "null"
            ]
          },
          "cloud_target_pressure": {
            "type": [
              "string",
              "null"
            ]
          },
          "v105_native_target_pressure": {
            "type": [
              "string",
              "null"
            ]
          },
          "final_target_pressure": {
            "type": [
              "string",
              "null"
            ]
          },
          "target_origin_bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "v105_native_driver_bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
