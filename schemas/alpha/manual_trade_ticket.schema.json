{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Manual Trade Ticket",
  "type": "object",
  "required": [
    "version",
    "status",
    "generated_at",
    "safe_mode",
    "summary",
    "not_trade_order",
    "execution_permission",
    "trade_signal_enabled"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "safe_mode": {
      "type": "boolean"
    },
    "summary": {
      "type": "object"
    },
    "not_trade_order": {
      "type": "boolean"
    },
    "execution_permission": {
      "type": "boolean"
    },
    "trade_signal_enabled": {
      "type": "boolean"
    },
    "broker_submission_enabled": {
      "type": "boolean"
    },
    "official_rebalance_enabled": {
      "type": "boolean"
    }
  }
}