{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alpha research sandbox",
  "type": "object",
  "required": [
    "version",
    "status",
    "safe_mode",
    "research_only",
    "trade_signal_enabled",
    "execution_permission",
    "not_trade_order",
    "alpha_model_enabled",
    "official_alpha_enabled",
    "maximum_sharpe_optimization_enabled",
    "model_policy",
    "asset_alpha_research",
    "summary"
  ],
  "properties": {
    "version": {"type": "string"},
    "status": {"type": "string"},
    "safe_mode": {"type": "boolean"},
    "research_only": {"type": "boolean"},
    "trade_signal_enabled": {"type": "boolean"},
    "execution_permission": {"type": "boolean"},
    "not_trade_order": {"type": "boolean"},
    "alpha_model_enabled": {"type": "boolean"},
    "official_alpha_enabled": {"type": "boolean"},
    "maximum_sharpe_optimization_enabled": {"type": "boolean"},
    "model_policy": {"type": "object"},
    "asset_alpha_research": {"type": "array"},
    "summary": {"type": "object"}
  }
}
