{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frontend build status",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "status"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "runtime_matches_source": {
      "type": "boolean"
    }
  }
}
